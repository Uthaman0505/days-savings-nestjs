APP_PORT=5000
# Postgres connection (first match wins: DATABASE_URL, then DB_DEVELOPMENT_URL)
# Railway: use the PUBLIC URL from the Postgres service (Connect / Variables).
# Do NOT use *.railway.internal for local dev — that host only works inside Railway's network.
DATABASE_URL=postgresql://postgres:ARlJCotyTWsMWiPlIBaBrVQRPvXfulXM@centerbeam.proxy.rlwy.net:24873/railway
DB_DEVELOPMENT_URL=
JWT_SECRET=change-me-to-a-long-random-string
# Short-lived access tokens; use refresh token to obtain new pairs
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_REFRESH_EXPIRES_IN=7d
# Set to false in production and use migrations instead of synchronize
TYPEORM_SYNC=true

# S3-compatible storage (profile avatars). Omit STORAGE_PUT_OBJECT_ACL if bucket ACLs are disabled.
STORAGE_ENDPOINT=https://t3.storageapi.dev
STORAGE_REGION=auto
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
# Virtual-hosted public base, e.g. https://<bucket>.t3.storageapi.dev
STORAGE_PUBLIC_BASE_URL=
STORAGE_FORCE_PATH_STYLE=false
# Optional: STORAGE_PUT_OBJECT_ACL=public-read